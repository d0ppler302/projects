// Validation implementation

pub fn validate_event(event: &Event, team_state: &TeamState) -> Result<(), ValidationError> {
    validate_event_id(event)?;
    validate_signature(event)?;
    validate_device_not_revoked(event, team_state)?;
    validate_clock_monotonicity(event, team_state)?;
    validate_authority(event, team_state)?;
    Ok(())
}

fn validate_event_id(event: &Event) -> Result<(), ValidationError> {
    let computed_id = event.compute_event_id();
    if computed_id != event.event_id {
        return Err(ValidationError::InvalidEventID);
    }
    Ok(())
}

fn validate_signature(event: &Event) -> Result<(), ValidationError> {
    let public_key_bytes = event.author_device_id.as_bytes();
    let verifying_key = VerifyingKey::from_bytes(public_key_bytes)
        .map_err(|_| ValidationError::InvalidSignature)?;
    
    let signature_bytes = event.signature.as_bytes();
    let ed25519_sig = Ed25519Signature::from_bytes(signature_bytes);
    
    let canonical_bytes = event.canonical_bytes_without_signature();
    
    verifying_key
        .verify(&canonical_bytes, &ed25519_sig)
        .map_err(|_| ValidationError::InvalidSignature)?;
    
    Ok(())
}

fn validate_device_not_revoked(event: &Event, team_state: &TeamState) -> Result<(), ValidationError> {
    if let EventPayload::GenesisEvent(_) = event.payload {
        return Ok(());
    }
    
    if let Some(device_state) = team_state.devices.get(&event.author_device_id) {
        if device_state.is_revoked {
            if let Some(revoked_at_clock) = device_state.revoked_at_clock {
                if event.logical_clock > revoked_at_clock {
                    return Err(ValidationError::DeviceRevoked);
                }
            } else {
                return Err(ValidationError::DeviceRevoked);
            }
        }
    }
    
    Ok(())
}

fn validate_clock_monotonicity(event: &Event, team_state: &TeamState) -> Result<(), ValidationError> {
    if let Some(device_state) = team_state.devices.get(&event.author_device_id) {
        let max_clock = find_max_clock_for_device(&event.author_device_id, team_state);
        if event.logical_clock.value() <= max_clock {
            return Err(ValidationError::ClockNotMonotonic);
        }
    }
    
    Ok(())
}

fn find_max_clock_for_device(device_id: &DeviceID, team_state: &TeamState) -> u64 {
    0
}

fn validate_authority(event: &Event, team_state: &TeamState) -> Result<(), ValidationError> {
    match &event.payload {
        EventPayload::GenesisEvent(data) => {
            if event.author_device_id != data.founding_device_id {
                return Err(ValidationError::InsufficientAuthority);
            }
            Ok(())
        }
        EventPayload::AddMember(_) => {
            validate_leader_authority(event, team_state)
        }
        EventPayload::RemoveMember(_) => {
            validate_leader_authority(event, team_state)
        }
        EventPayload::BindDeviceToUser(data) => {
            if event.author_device_id != data.device_id {
                return Err(ValidationError::InsufficientAuthority);
            }
            Ok(())
        }
        EventPayload::PromoteLeader(_) => {
            validate_leader_authority(event, team_state)
        }
        EventPayload::DemoteLeader(_) => {
            validate_leader_authority(event, team_state)
        }
        EventPayload::RemoveLeader(_) => {
            validate_leader_authority(event, team_state)
        }
        EventPayload::RevokeDevice(_) => {
            validate_leader_authority(event, team_state)
        }
        EventPayload::CastVoteForLeader(_) => {
            validate_member_authority(event, team_state)
        }
        EventPayload::ResolveConflict(_) => {
            validate_leader_authority(event, team_state)
        }
    }
}

fn validate_leader_authority(event: &Event, team_state: &TeamState) -> Result<(), ValidationError> {
    let device_state = team_state.devices.get(&event.author_device_id)
        .ok_or(ValidationError::UnknownDevice)?;
    
    let user_id = device_state.user_id
        .ok_or(ValidationError::DeviceNotBound)?;
    
    let member_state = team_state.members.get(&user_id)
        .ok_or(ValidationError::InsufficientAuthority)?;
    
    if !member_state.is_leader {
        return Err(ValidationError::InsufficientAuthority);
    }
    
    if !member_state.is_active {
        return Err(ValidationError::InsufficientAuthority);
    }
    
    Ok(())
}

fn validate_member_authority(event: &Event, team_state: &TeamState) -> Result<(), ValidationError> {
    let device_state = team_state.devices.get(&event.author_device_id)
        .ok_or(ValidationError::UnknownDevice)?;
    
    let user_id = device_state.user_id
        .ok_or(ValidationError::DeviceNotBound)?;
    
    let member_state = team_state.members.get(&user_id)
        .ok_or(ValidationError::InsufficientAuthority)?;
    
    if !member_state.is_active {
        return Err(ValidationError::InsufficientAuthority);
    }
    
    Ok(())
}

// Replay implementation

pub fn apply_event(
    event: &Event,
    team_state: &mut TeamState,
) -> Result<(), ReplayError> {
    match &event.payload {
        EventPayload::GenesisEvent(data) => apply_genesis(event, data, team_state),
        EventPayload::AddMember(data) => apply_add_member(data, team_state),
        EventPayload::RemoveMember(data) => apply_remove_member(data, team_state),
        EventPayload::BindDeviceToUser(data) => apply_bind_device_to_user(data, team_state),
        EventPayload::PromoteLeader(data) => apply_promote_leader(data, team_state),
        EventPayload::DemoteLeader(data) => apply_demote_leader(data, team_state),
        EventPayload::RemoveLeader(data) => apply_remove_leader(data, team_state),
        EventPayload::RevokeDevice(data) => apply_revoke_device(event, data, team_state),
        EventPayload::CastVoteForLeader(data) => apply_cast_vote_for_leader(event, data, team_state),
        EventPayload::ResolveConflict(data) => apply_resolve_conflict(data, team_state),
    }
}

fn apply_genesis(
    event: &Event,
    data: &GenesisEventData,
    team_state: &mut TeamState,
) -> Result<(), ReplayError> {
    if !team_state.members.is_empty() || !team_state.devices.is_empty() {
        return Err(ReplayError::TeamStateNotEmpty);
    }

    team_state.team_id = data.team_id;
    
    let mut founding_devices = BTreeMap::new();
    founding_devices.insert(data.founding_device_id, ());
    
    let founding_member = MemberState {
        user_id: data.founding_user_id,
        is_active: true,
        is_leader: true,
        devices: founding_devices,
    };
    
    team_state.members.insert(data.founding_user_id, founding_member);
    
    let founding_device = DeviceState {
        device_id: data.founding_device_id,
        user_id: Some(data.founding_user_id),
        is_revoked: false,
        revoked_at_clock: None,
    };
    
    team_state.devices.insert(data.founding_device_id, founding_device);
    team_state.is_leaderless = false;
    
    Ok(())
}

fn apply_add_member(
    data: &AddMemberData,
    team_state: &mut TeamState,
) -> Result<(), ReplayError> {
    team_state.members.entry(data.user_id).or_insert_with(|| MemberState {
        user_id: data.user_id,
        is_active: true,
        is_leader: false,
        devices: BTreeMap::new(),
    });
    
    if let Some(member) = team_state.members.get_mut(&data.user_id) {
        member.is_active = true;
    }
    
    Ok(())
}

fn apply_remove_member(
    data: &RemoveMemberData,
    team_state: &mut TeamState,
) -> Result<(), ReplayError> {
    let member = team_state.members.get_mut(&data.user_id)
        .ok_or(ReplayError::MemberNotFound)?;
    
    member.is_active = false;
    
    if member.is_leader {
        member.is_leader = false;
    }
    
    team_state.active_votes.retain(|voter_id, _| *voter_id != data.user_id);
    
    update_leaderless_status(team_state);
    
    Ok(())
}

fn apply_bind_device_to_user(
    data: &BindDeviceToUserData,
    team_state: &mut TeamState,
) -> Result<(), ReplayError> {
    team_state.devices.entry(data.device_id).or_insert_with(|| DeviceState {
        device_id: data.device_id,
        user_id: None,
        is_revoked: false,
        revoked_at_clock: None,
    });
    
    if let Some(device) = team_state.devices.get_mut(&data.device_id) {
        device.user_id = Some(data.user_id);
    }
    
    if let Some(member) = team_state.members.get_mut(&data.user_id) {
        member.devices.insert(data.device_id, ());
    }
    
    Ok(())
}

fn apply_promote_leader(
    data: &PromoteLeaderData,
    team_state: &mut TeamState,
) -> Result<(), ReplayError> {
    let member = team_state.members.get_mut(&data.user_id)
        .ok_or(ReplayError::MemberNotFound)?;
    
    member.is_leader = true;
    team_state.is_leaderless = false;
    
    Ok(())
}

fn apply_demote_leader(
    data: &DemoteLeaderData,
    team_state: &mut TeamState,
) -> Result<(), ReplayError> {
    let member = team_state.members.get_mut(&data.user_id)
        .ok_or(ReplayError::MemberNotFound)?;
    
    member.is_leader = false;
    
    update_leaderless_status(team_state);
    
    Ok(())
}

fn apply_remove_leader(
    data: &RemoveLeaderData,
    team_state: &mut TeamState,
) -> Result<(), ReplayError> {
    apply_demote_leader(&DemoteLeaderData { user_id: data.user_id }, team_state)
}

fn apply_revoke_device(
    event: &Event,
    data: &RevokeDeviceData,
    team_state: &mut TeamState,
) -> Result<(), ReplayError> {
    let device = team_state.devices.get_mut(&data.device_id)
        .ok_or(ReplayError::DeviceNotFound)?;
    
    device.is_revoked = true;
    device.revoked_at_clock = Some(event.logical_clock);
    
    Ok(())
}

fn apply_cast_vote_for_leader(
    event: &Event,
    data: &CastVoteForLeaderData,
    team_state: &mut TeamState,
) -> Result<(), ReplayError> {
    let device_state = team_state.devices.get(&event.author_device_id)
        .ok_or(ReplayError::DeviceNotFound)?;
    
    let voter_user_id = device_state.user_id
        .ok_or(ReplayError::MemberNotFound)?;
    
    let vote_record = VoteRecord {
        voter_user_id,
        candidate_user_id: data.candidate_user_id,
        vote_event_id: event.event_id,
    };
    
    team_state.active_votes.insert(voter_user_id, vote_record);
    
    if team_state.is_leaderless {
        check_and_finalize_election(team_state)?;
    }
    
    Ok(())
}

fn apply_resolve_conflict(
    data: &ResolveConflictData,
    team_state: &mut TeamState,
) -> Result<(), ReplayError> {
    if !team_state.conflicted_objects.contains_key(&data.conflict_id) {
        return Err(ReplayError::ConflictNotFound);
    }
    
    team_state.conflicted_objects.remove(&data.conflict_id);
    
    Ok(())
}

fn update_leaderless_status(team_state: &mut TeamState) {
    let has_active_leader = team_state.members.values()
        .any(|member| member.is_active && member.is_leader);
    
    team_state.is_leaderless = !has_active_leader;
}

fn check_and_finalize_election(team_state: &mut TeamState) -> Result<(), ReplayError> {
    let active_member_count = team_state.members.values()
        .filter(|member| member.is_active)
        .count();
    
    if active_member_count == 0 {
        return Ok(());
    }
    
    let majority_threshold = (active_member_count / 2) + 1;
    
    let mut vote_counts: BTreeMap<UserID, usize> = BTreeMap::new();
    
    for vote in team_state.active_votes.values() {
        *vote_counts.entry(vote.candidate_user_id).or_insert(0) += 1;
    }
    
    for (candidate_id, vote_count) in vote_counts.iter() {
        if *vote_count >= majority_threshold {
            if let Some(candidate_member) = team_state.members.get_mut(candidate_id) {
                candidate_member.is_leader = true;
                team_state.is_leaderless = false;
                team_state.active_votes.clear();
                break;
            }
        }
    }
    
    Ok(())
}
