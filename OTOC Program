// Event structure

#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]
pub struct Event {
    pub event_id: EventID,
    pub author_device_id: DeviceID,
    pub logical_clock: LogicalClock,
    pub payload: EventPayload,
    pub signature: Signature,
}

#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]
struct EventWithoutSignature {
    author_device_id: DeviceID,
    logical_clock: LogicalClock,
    payload: EventPayload,
}

impl Event {
    pub fn canonical_bytes_without_signature(&self) -> Vec<u8> {
        let event_without_sig = EventWithoutSignature {
            author_device_id: self.author_device_id,
            logical_clock: self.logical_clock,
            payload: self.payload.clone(),
        };

        serde_cbor::to_vec(&event_without_sig).expect("CBOR serialization must succeed")
    }

    pub fn compute_event_id(&self) -> EventID {
        let canonical_bytes = self.canonical_bytes_without_signature();
        let mut hasher = Sha256::new();
        hasher.update(&canonical_bytes);
        let hash_result = hasher.finalize();
        let mut hash_bytes = [0u8; 32];
        hash_bytes.copy_from_slice(&hash_result);
        EventID::new(hash_bytes)
    }
}

