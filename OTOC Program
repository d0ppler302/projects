#[derive(Debug, Clone, PartialEq, Eq)]
pub struct TeamState {
    pub team_id: TeamID,
    pub members: BTreeMap<UserID, MemberState>,
    pub devices: BTreeMap<DeviceID, DeviceState>,
    pub is_leaderless: bool,
    pub active_votes: BTreeMap<UserID, VoteRecord>,
    pub conflicted_objects: BTreeMap<ConflictID, ConflictedObject>,
    pub seen_event_ids: BTreeMap<EventID, ()>,
}

impl TeamState {
    pub fn new_empty() -> Self {
        Self {
            team_id: TeamID([0u8; 32]),
            members: BTreeMap::new(),
            devices: BTreeMap::new(),
            is_leaderless: true,
            active_votes: BTreeMap::new(),
            conflicted_objects: BTreeMap::new(),
            seen_event_ids: BTreeMap::new(),
        }
    }

    pub fn update_leaderless_status(&mut self) {
        self.is_leaderless = !self.members.values().any(|m| m.is_leader && m.is_active);
    }

    pub fn tally_leader_votes(&mut self) {
        let n = self.members.values().filter(|m| m.is_active).count();
        if n == 0 { return; }

        let threshold = (n / 2) + 1;
        let mut counts: BTreeMap<UserID, usize> = BTreeMap::new();
        
        for vote in self.active_votes.values() {
            if let Some(member) = self.members.get(&vote.candidate_user_id) {
                if member.is_active {
                    *counts.entry(vote.candidate_user_id).or_insert(0) += 1;
                }
            }
        }

        if let Some((&winner, _)) = counts.iter().find(|&(_, &count)| count >= threshold) {
            if let Some(member) = self.members.get_mut(&winner) {
                member.is_leader = true;
                self.is_leaderless = false;
                self.active_votes.clear();
            }
        }
    }
}

//
// Utility & Validation
//

pub fn device_id_from_public_key(pubkey: &[u8; 32]) -> DeviceID {
    let mut hasher = Sha256::new();
    hasher.update(pubkey);
    let hash = hasher.finalize();
    let mut out = [0u8; 32];
    out.copy_from_slice(&hash);
    DeviceID::new(out)
}

#[derive(Debug)]
pub enum ValidationError {
    InvalidEventID,
    InvalidSignature,
    UnknownDevice,
    ClockNotMonotonic,
    DeviceRevoked,
    UnauthorizedAction,
    AlreadyInitialized,
}

pub fn validate_event(event: &Event, team_state: &TeamState) -> Result<(), ValidationError> {
    if event.compute_event_id() != event.event_id {
        return Err(ValidationError::InvalidEventID);
    }
    validate_authority(event, team_state)?;
    validate_signature(event, team_state)?;
    validate_device_status(event, team_state)?;
    Ok(())
}

fn validate_authority(event: &Event, team_state: &TeamState) -> Result<(), ValidationError> {
    match &event.payload {
        EventPayload::GenesisEvent(_) => {
            if !team_state.team_id.is_zero() { return Err(ValidationError::AlreadyInitialized); }
        }
        _ => {
            let device = team_state.devices.get(&event.author_device_id).ok_or(ValidationError::UnknownDevice)?;
            let user_id = device.user_id.ok_or(ValidationError::UnauthorizedAction)?;
            let member = team_state.members.get(&user_id).ok_or(ValidationError::UnauthorizedAction)?;

            if !member.is_active { return Err(ValidationError::UnauthorizedAction); }

            match &event.payload {
                EventPayload::AddMember(_) | EventPayload::RemoveMember(_) |
                EventPayload::PromoteLeader(_) | EventPayload::DemoteLeader(_) |
                EventPayload::RemoveLeader(_) | EventPayload::RevokeDevice(_) |
                EventPayload::ResolveConflict(_) => {
                    if !member.is_leader { return Err(ValidationError::UnauthorizedAction); }
                },
                EventPayload::CastVoteForLeader(_) => {
                    if let Some(last_clock) = member.last_vote_clock {
                        if event.logical_clock.value() <= last_clock.value() {
                            return Err(ValidationError::ClockNotMonotonic);
                        }
                    }
                }
                _ => {}
            }
        }
    }
    Ok(())
}

fn validate_signature(event: &Event, team_state: &TeamState) -> Result<(), ValidationError> {
    let public_key = match &event.payload {
        EventPayload::GenesisEvent(data) => {
            let expected_id = device_id_from_public_key(&data.founding_device_public_key);
            if expected_id != data.founding_device_id {
                return Err(ValidationError::InvalidSignature);
            }
            &data.founding_device_public_key
        }
        _ => &team_state.devices.get(&event.author_device_id).ok_or(ValidationError::UnknownDevice)?.public_key,
    };

    let verifying_key = VerifyingKey::from_bytes(public_key).map_err(|_| ValidationError::InvalidSignature)?;
    let sig = Ed25519Signature::from_bytes(event.signature.as_bytes());

    verifying_key.verify(&event.canonical_bytes_without_signature(), &sig)
        .map_err(|_| ValidationError::InvalidSignature)?;
    Ok(())
}

fn validate_device_status(event: &Event, team_state: &TeamState) -> Result<(), ValidationError> {
    if let Some(device) = team_state.devices.get(&event.author_device_id) {
        if device.is_revoked { return Err(ValidationError::DeviceRevoked); }
        if event.logical_clock.value() <= device.last_clock.value() {
            return Err(ValidationError::ClockNotMonotonic);
        }
    }
    Ok(())
}

//
// Application Logic
//

#[derive(Debug)]
pub enum ReplayError {
    ValidationFailed(ValidationError),
    DuplicateEvent,
    InvariantViolation,
}

pub fn apply_event(event: &Event, team_state: &mut TeamState) -> Result<(), ReplayError> {
    validate_event(event, team_state).map_err(ReplayError::ValidationFailed)?;

    if team_state.seen_event_ids.contains_key(&event.event_id) {
        return Err(ReplayError::DuplicateEvent);
    }
    team_state.seen_event_ids.insert(event.event_id, ());

    match &event.payload {
        EventPayload::GenesisEvent(data) => apply_genesis(event, data, team_state)?,
        EventPayload::AddMember(data) => apply_add_member(data, team_state)?,
        EventPayload::RemoveMember(data) => apply_remove_member(data, team_state)?,
        EventPayload::BindDeviceToUser(data) => apply_bind_device(event, data, team_state)?,
        EventPayload::PromoteLeader(data) => promote_leader(data, team_state)?,
        EventPayload::DemoteLeader(data) => demote_leader(data, team_state)?,
        EventPayload::RemoveLeader(data) => remove_leader(data, team_state)?,
        EventPayload::RevokeDevice(data) => revoke_device(event, data, team_state)?,
        EventPayload::CastVoteForLeader(data) => cast_vote(event, data, team_state)?,
        EventPayload::ResolveConflict(data) => resolve_conflict(data, team_state)?,
    }

    if let Some(device) = team_state.devices.get_mut(&event.author_device_id) {
        device.last_clock = event.logical_clock;
    }

    Ok(())
}

fn apply_genesis(event: &Event, data: &GenesisEventData, team_state: &mut TeamState) -> Result<(), ReplayError> {
    team_state.team_id = data.team_id;
    team_state.devices.insert(data.founding_device_id, DeviceState {
        device_id: data.founding_device_id,
        public_key: data.founding_device_public_key,
        user_id: Some(data.founding_user_id),
        is_revoked: false,
        revoked_at_clock: None,
        last_clock: event.logical_clock,
    });
    team_state.members.insert(data.founding_user_id, MemberState {
        user_id: data.founding_user_id,
        is_active: true,
        is_leader: true,
        devices: {
            let mut m = BTreeMap::new();
            m.insert(data.founding_device_id, ());
            m
        },
        last_vote_clock: None,
    });
    team_state.is_leaderless = false;
    Ok(())
}

fn apply_add_member(data: &AddMemberData, team_state: &mut TeamState) -> Result<(), ReplayError> {
    team_state.members.entry(data.user_id).or_insert(MemberState {
        user_id: data.user_id,
        is_active: true,
        is_leader: false,
        devices: BTreeMap::new(),
        last_vote_clock: None,
    });
    Ok(())
}

fn apply_remove_member(data: &RemoveMemberData, team_state: &mut TeamState) -> Result<(), ReplayError> {
    if let Some(member) = team_state.members.get_mut(&data.user_id) {
        member.is_active = false;
        member.is_leader = false;
        for dev_id in member.devices.keys() {
            if let Some(dev) = team_state.devices.get_mut(dev_id) {
                dev.is_revoked = true;
            }
        }
        team_state.active_votes.remove(&data.user_id);
        team_state.active_votes.retain(|_, v| v.candidate_user_id != data.user_id);
    }
    team_state.update_leaderless_status();
    Ok(())
}

fn apply_bind_device(event: &Event, data: &BindDeviceToUserData, team_state: &mut TeamState) -> Result<(), ReplayError> {
    team_state.devices.insert(data.device_id, DeviceState {
        device_id: data.device_id,
        public_key: data.device_public_key,
        user_id: Some(data.user_id),
        is_revoked: false,
        revoked_at_clock: None,
        last_clock: event.logical_clock,
    });
    if let Some(member) = team_state.members.get_mut(&data.user_id) {
        member.devices.insert(data.device_id, ());
    }
    Ok(())
}

fn promote_leader(data: &PromoteLeaderData, team_state: &mut TeamState) -> Result<(), ReplayError> {
    if let Some(member) = team_state.members.get_mut(&data.user_id) {
        member.is_leader = true;
    }
    team_state.update_leaderless_status();
    Ok(())
}

fn demote_leader(data: &DemoteLeaderData, team_state: &mut TeamState) -> Result<(), ReplayError> {
    if let Some(member) = team_state.members.get_mut(&data.user_id) {
        member.is_leader = false;
    }
    team_state.update_leaderless_status();
    Ok(())
}

fn remove_leader(data: &RemoveLeaderData, team_state: &mut TeamState) -> Result<(), ReplayError> {
    if let Some(member) = team_state.members.get_mut(&data.user_id) {
        member.is_leader = false;
